# LLM API credentials
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Generation hyperparameters (optional)
# MAX_NEW_TOKENS=16000
# TEMPERATURE=0

# Embedding model for canonicalization (optional)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Canonicalization hyperparameters (optional)
# CLUSTER_SIZE=128
# TOP_K_CANDIDATES=16

# Output directory (optional; CLI --output-dir overrides this)
# SOKG_OUTPUT_DIR=outputs/SoKG
